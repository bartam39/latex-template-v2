% cheatsheet.sty — Core Layout, Typography, and Custom Commands
% Professional compact cheat sheet style with Material Design aesthetics
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/cheatsheet}[2026/03/22 CS/AI Cheat Sheet Style]

% =============================================================================
% DEPENDENCIES — ordered to avoid conflicts
% =============================================================================
\RequirePackage{style/colors}

% Fix Computer Modern math fonts at arbitrary sizes (eliminates substitution warnings)
\RequirePackage{fix-cm}

% Font encoding BEFORE font packages
\RequirePackage[T1]{fontenc}

% Font setup
\IfFileExists{roboto.sty}{%
  \RequirePackage[sfdefault, light]{roboto}%
}{%
  \RequirePackage[scaled=0.90]{helvet}%
  \renewcommand{\familydefault}{\sfdefault}%
}

% Page geometry
\RequirePackage[landscape, a4paper, left=3.5mm, right=3.5mm, top=3.5mm, bottom=3.5mm, includeheadfoot, headheight=7pt, headsep=0.8mm, footskip=4pt]{geometry}

% Core packages
\RequirePackage{multicol}
\RequirePackage{amssymb, amsfonts}
\RequirePackage{mathtools}           % Loads amsmath internally
\RequirePackage{enumitem}
\RequirePackage{style/minted}
\RequirePackage[noend, noline, algo2e]{algorithm2e}
\RequirePackage{tcolorbox}
\RequirePackage{tabularx}
% booktabs intentionally omitted — \toprule/\midrule add too much vspace for 5-col
\RequirePackage{fancyhdr}
\RequirePackage{etoolbox}
\RequirePackage{titlesec}
\RequirePackage{ragged2e}            % Better ragged text in narrow columns

% hyperref LAST to avoid cross-reference conflicts
\RequirePackage{hyperref}

\tcbuselibrary{skins, breakable}

% =============================================================================
% BASE TYPOGRAPHY — scaled down for 5-column density
% =============================================================================
\renewcommand{\normalsize}{\fontsize{5.5}{6.6}\selectfont}
\renewcommand{\small}{\fontsize{5}{6}\selectfont}
\renewcommand{\footnotesize}{\fontsize{4.5}{5.4}\selectfont}
\renewcommand{\scriptsize}{\fontsize{4}{4.8}\selectfont}
\renewcommand{\tiny}{\fontsize{3.5}{4.2}\selectfont}
\renewcommand{\large}{\fontsize{6.5}{7.8}\selectfont}
\renewcommand{\Large}{\fontsize{7.5}{9}\selectfont}

\normalsize
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5pt plus 0.25pt}
\setlength{\abovedisplayskip}{1.5pt}
\setlength{\belowdisplayskip}{1.5pt}
\setlength{\abovedisplayshortskip}{0.5pt}
\setlength{\belowdisplayshortskip}{0.5pt}

% Tighter math spacing
\medmuskip=2mu
\thickmuskip=3mu

% Better typography in narrow columns
\RaggedRight

% =============================================================================
% COLUMN LAYOUT — 5 columns, vertical flow
% =============================================================================
\setlength{\columnsep}{3mm}
\setlength{\columnseprule}{0pt}
\raggedcolumns

% Prevent orphans/widows that push content to next page
\widowpenalty=10000
\clubpenalty=10000
\brokenpenalty=10000

% Allow display equations to break across columns
\allowdisplaybreaks

% Allow multicol to stretch columns to fill page
\setlength{\multicolsep}{0pt}
\setlength{\premulticols}{0pt}
\setlength{\postmulticols}{0pt}
\setlength{\multicolundershoot}{10pt}
\setlength{\multicolovershoot}{10pt}

% Reduce float penalties to avoid column overflow
\@ifundefined{c@collectmore}{}{%
  \setcounter{collectmore}{-1}%
}

% =============================================================================
% HEADER / FOOTER — minimal
% =============================================================================
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[L]{%
  \tiny\color{heading}\textbf{\@title}%
}
\fancyhead[R]{%
  \tiny\color{textSecondary}\@author\ |\ \@date%
}

% =============================================================================
% SECTION HEADINGS — Ultra Compact
% =============================================================================
\titleformat{\section}
  {\large\bfseries\color{heading}}
  {}
  {0pt}
  {}
  [\vspace{-1.5pt}{\color{heading}\hrule height 0.4pt}\vspace{1pt}]

\titlespacing*{\section}{0pt}{2.5pt}{1pt}

\titleformat{\subsection}
  {\normalsize\bfseries\color{secondary}}
  {}
  {0pt}
  {}

\titlespacing*{\subsection}{0pt}{2pt}{0.5pt}

\titleformat{\subsubsection}
  {\small\bfseries\color{textPrimary}}
  {}
  {0pt}
  {}

\titlespacing*{\subsubsection}{0pt}{1.5pt}{0.3pt}

% =============================================================================
% COMPACT LISTS
% =============================================================================
\setlist{
  nosep,
  leftmargin=1em,
  labelwidth=0.6em,
  labelsep=0.2em,
  topsep=0pt,
  partopsep=0pt,
  parsep=0pt,
  itemsep=0.3pt,
}
\setlist[itemize,1]{label={\color{primary}\textbullet}}
\setlist[itemize,2]{label={\color{secondary}\textendash}, leftmargin=0.8em}
\setlist[enumerate,1]{label={\color{primary}\arabic*.}}

% Description list for definitions
\newlist{deflist}{description}{1}
\setlist[deflist]{
  nosep,
  leftmargin=0pt,
  labelwidth=0pt,
  labelsep=0.4em,
  itemsep=0.5pt,
  font=\small\bfseries\color{primary},
}

% =============================================================================
% CODE HIGHLIGHTING — Minted (Pygments-based)
% =============================================================================
% Compile with: pdflatex -shell-escape main.tex
\setminted{
  fontsize=\tiny,
  breaklines=true,
  tabsize=2,
  bgcolor=codeBg,
  frame=leftline,
  framerule=0.4pt,
  framesep=1.5pt,
  rulecolor=\color{codeBorder},
  xleftmargin=1pt,
  xrightmargin=0pt,
}

% Language-specific overrides
\setminted[python]{python3=true}

% Compact code block command: \codeblock{language}{code}
\newcommand{\codeblock}[2]{%
  \vspace{0.5pt}%
  \begin{minted}{#1}
#2
  \end{minted}%
  \vspace{0.5pt}%
}

% =============================================================================
% ALGORITHM2E — Pseudocode (ultra-compact)
% =============================================================================
\SetAlFnt{\tiny}
\SetAlCapFnt{\tiny\bfseries\color{primary}}
\SetAlCapNameFnt{\tiny\bfseries\color{primary}}
\SetKwSty{textbf}
\SetFuncSty{textsf}
\SetArgSty{textnormal}
\SetCommentSty{itshape\color{codeComment}}
\SetKwComment{tcp}{// }{}
\SetNlSty{tiny}{}{.}
\SetNlSkip{0.2em}
\SetAlgoNlRelativeSize{-1}
\SetAlgoSkip{}
\SetAlgoInsideSkip{}
\SetAlCapSkip{0pt}
\setlength{\algomargin}{1pt}
\SetInd{0.3em}{0.4em}
\DontPrintSemicolon

% =============================================================================
% TCOLORBOX STYLES — Parameterized Base + Derived Boxes
% =============================================================================

% Shared box padding
\newlength{\boxpadtop}    \setlength{\boxpadtop}{1pt}
\newlength{\boxpadbottom} \setlength{\boxpadbottom}{1pt}
\newlength{\boxpadleft}   \setlength{\boxpadleft}{3pt}
\newlength{\boxpadright}  \setlength{\boxpadright}{1pt}
\newlength{\boxskip}      \setlength{\boxskip}{1.5pt}

% Base style: \accentbox[color]{title}{...} — all accent boxes derive from this
\tcbset{
  accentboxbase/.style={
    enhanced,
    colback=surface,
    colframe=surface,
    boxrule=0pt,
    arc=0pt, outer arc=0pt,
    top=\boxpadtop, bottom=\boxpadbottom, left=\boxpadleft, right=\boxpadright,
    before skip=\boxskip, after skip=\boxskip,
    colbacktitle=surface,
    attach boxed title to top left={xshift=0pt, yshift=0pt},
    boxed title style={boxrule=0pt, colframe=surface, arc=0pt, top=0pt, bottom=0pt, left=0pt, right=0pt},
    toptitle=0pt, bottomtitle=0pt,
  },
  accentbox/.style={
    accentboxbase,
    borderline west={1.5pt}{0pt}{#1},
    fonttitle=\scriptsize\bfseries\color{#1},
  },
}

% Algorithm/code box (different bg + thinner border)
\newtcolorbox{algobox}[1][]{%
  enhanced,
  colback=codeBg,
  colframe=codeBg,
  boxrule=0pt,
  borderline west={1pt}{0pt}{secondary},
  arc=0pt, outer arc=0pt,
  top=1pt, bottom=1pt, left=2pt, right=1pt,
  before skip=1pt, after skip=1pt,
  fonttitle=\scriptsize\bfseries\color{secondary},
  colbacktitle=codeBg,
  attach boxed title to top left={xshift=0pt, yshift=0pt},
  boxed title style={boxrule=0pt, colframe=codeBg, arc=0pt, top=0pt, bottom=0.5pt, left=0pt, right=0pt},
  title={#1},
  toptitle=0pt, bottomtitle=0pt,
}

% Derived accent boxes — one-liner each thanks to base style
\newtcolorbox{defbox}[1][]{accentbox=primary, title={#1}}
\newtcolorbox{thmbox}[1][]{accentbox=secondary, title={#1}}
\newtcolorbox{notebox}[1][]{accentbox=accent, title={#1}}
\newtcolorbox{warnbox}[1][]{accentbox=warning, title={#1}}
\newtcolorbox{successbox}[1][]{accentbox=success, title={#1}}
\newtcolorbox{infobox}[1][]{accentbox=info, title={#1}}

% Inline highlight box (single-line, no title)
\newtcbox{\hlbox}[1][primary]{%
  on line, arc=1pt, outer arc=1pt,
  colback=surface, colframe=#1,
  boxsep=0pt, left=2pt, right=2pt, top=0.5pt, bottom=0.5pt,
  boxrule=0.3pt,
}

% =============================================================================
% CUSTOM COMMANDS — Core
% =============================================================================

% Formula: \formula{Name}{$equation$}
\newcommand{\formula}[2]{%
  \par\noindent
  {\small\bfseries\color{primary}#1}\hfill{\small #2}\par
  \vspace{0.5pt}%
}

% Algorithm entry: \algo{Name}{O(...)}{Description}
\newcommand{\algo}[3]{%
  \par\noindent
  {\small\bfseries\color{primary}#1}%
  \hfill{\footnotesize\color{accent}#2}\\*
  {\footnotesize #3}\par
  \vspace{0.5pt}%
}

% Inline code
\newcommand{\code}[1]{\texttt{\small\color{codeKeyword}#1}}

% Key-value pair for quick reference tables
\newcommand{\kv}[2]{%
  {\small\bfseries\color{textPrimary}#1:}~{\small #2}%
}

% =============================================================================
% CUSTOM COMMANDS — Utilities
% =============================================================================

% Compact 2-column mini-table: \minitable{col1 & col2 \\ ...}
\newcommand{\minitable}[1]{%
  \vspace{0.5pt}%
  \begin{tabularx}{\linewidth}{@{}lX@{}}
    #1
  \end{tabularx}%
  \vspace{0.5pt}%
}

% Compact table: \comptable{col-spec}{rows}
% Example: \comptable{@{}llll@{}}{Header1 & H2 & H3 & H4 \\ row...}
\newcommand{\comptable}[2]{%
  \vspace{0.5pt}%
  \begin{tabularx}{\linewidth}{#1}
    #2
  \end{tabularx}%
  \vspace{0.5pt}%
}

% Colored tag/badge: \tagc{color}{text}
\RequirePackage{tikz}  % Explicit dependency for tags
\newcommand{\tagc}[2]{%
  \tikz[baseline=(t.base)]{\node[fill=#1!12, text=#1, rounded corners=1pt,
    inner sep=1pt, font=\tiny\bfseries] (t) {#2};}%
}
\newcommand{\tagprimary}[1]{\hlbox[primary]{\tiny\bfseries\color{primary}#1}}
\newcommand{\tagsecondary}[1]{\hlbox[secondary]{\tiny\bfseries\color{secondary}#1}}
\newcommand{\tagaccent}[1]{\hlbox[accent]{\tiny\bfseries\color{accent}#1}}

% Quick comparison: \vs{A}{B}
\newcommand{\vs}[2]{%
  {\footnotesize\color{primary}\textbf{#1}} {\footnotesize vs} {\footnotesize\color{secondary}\textbf{#2}}%
}

% Step-by-step: \step{1}{text}
\newcommand{\step}[2]{%
  {\small\color{primary}\textbf{#1.}}~{\small #2}%
}

% Complexity badge: \bigO{n \log n}
\newcommand{\bigO}[1]{{\footnotesize\color{accent}$O(#1)$}}

% Separator with label: \labeledsep{text}
\newcommand{\labeledsep}[1]{%
  \vspace{1pt}%
  {\color{divider}\hrule height 0.2pt}%
  \vspace{-3pt}%
  \hfill{\tiny\color{textSecondary}\textit{#1}}\hfill\null%
  \vspace{0.5pt}%
}

% Compact definition inline: \defn{term}{meaning}
\newcommand{\defn}[2]{%
  \par\noindent{\small\bfseries\color{primary}#1}~{\small #2}\par%
}

% Matrix display helper: \mat{a & b \\ c & d}
\newcommand{\mat}[1]{\begin{pmatrix}#1\end{pmatrix}}

% =============================================================================
% MATH OPERATOR SHORTCUTS
% =============================================================================
\DeclareMathOperator*{\argmin}{arg\,min}
\DeclareMathOperator*{\argmax}{arg\,max}
\DeclareMathOperator{\sign}{sign}
\DeclareMathOperator{\softmax}{softmax}
\DeclareMathOperator{\relu}{ReLU}
\DeclareMathOperator{\sigmoid}{sigmoid}
\DeclareMathOperator{\diag}{diag}
\DeclareMathOperator{\rank}{rank}
\DeclareMathOperator{\tr}{tr}
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\E}{\mathbb{E}}
\newcommand{\Prob}{\mathbb{P}}
\newcommand{\Var}{\mathrm{Var}}
\newcommand{\Cov}{\mathrm{Cov}}
\newcommand{\KL}{\mathrm{KL}}
\newcommand{\norm}[1]{\left\lVert#1\right\rVert}
\newcommand{\abs}[1]{\left\lvert#1\right\rvert}
\newcommand{\inner}[2]{\langle#1,#2\rangle}
\newcommand{\pd}[2]{\frac{\partial #1}{\partial #2}}
\newcommand{\dd}[2]{\frac{d #1}{d #2}}

% =============================================================================
% HYPERREF CONFIG
% =============================================================================
\hypersetup{
  colorlinks=true,
  linkcolor=primary,
  urlcolor=primaryLight,
  citecolor=secondary,
  pdfborder={0 0 0},
}

% =============================================================================
% TABLE DEFAULTS — tighter for 5 columns
% =============================================================================
\renewcommand{\arraystretch}{1.0}
\setlength{\tabcolsep}{1.5pt}

\endinput
